<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Batman Surprise 🎂</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@1,600&family=Nunito:wght@300;400;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
<style>
:root{--pink:#ff4da6;--blue:#4db8ff;--gold:#ffd166;}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Nunito',sans-serif;background:radial-gradient(circle,#1a0a1f,#000);color:white;overflow-x:hidden;}
#start{height:100vh;display:flex;justify-content:center;align-items:center;background:black;}
.start-btn{padding:16px 30px;font-size:18px;border-radius:30px;border:none;color:white;cursor:pointer;background:linear-gradient(45deg,var(--pink),var(--blue));animation:pulse 2s infinite;}
@keyframes pulse{0%{box-shadow:0 0 10px var(--pink);}50%{box-shadow:0 0 25px var(--blue);}100%{box-shadow:0 0 10px var(--pink);}}
#main{display:none;text-align:center;padding:20px;}
.hero h1{font-family:'Playfair Display';font-size:2.8rem;}
#subtitle{margin-top:10px;opacity:0.8;}
.heart{position:fixed;bottom:-20px;animation:float 6s linear infinite;font-size:1.4rem;user-select:none;pointer-events:none;}
@keyframes float{to{transform:translateY(-110vh);opacity:0;}}
.cake{margin:30px auto;width:130px;height:130px;background:linear-gradient(#ffb6c1,#ff69b4);border-radius:15px;position:relative;}
.candle{position:absolute;top:-30px;left:50%;transform:translateX(-50%);width:10px;height:30px;background:white;}
.flame{width:10px;height:10px;background:orange;border-radius:50%;animation:flicker .3s infinite;}
@keyframes flicker{0%{opacity:1;}50%{opacity:.5;}}
.secret-btn{margin-top:20px;background:#111;border:1px solid var(--blue);}
#popup{position:fixed;inset:0;display:none;background:rgba(0,0,0,0.96);justify-content:center;align-items:center;z-index:999;padding:20px;overflow-y:auto;}
.popup-box{max-width:560px;width:100%;padding:36px 32px;background:linear-gradient(135deg,#0d0d1a,#111);border:1px solid var(--blue);border-radius:16px;position:relative;overflow:hidden;}
.popup-box::before{content:'';position:absolute;inset:0;background:repeating-linear-gradient(45deg,rgba(77,184,255,0.03) 0px,rgba(77,184,255,0.03) 1px,transparent 1px,transparent 10px);pointer-events:none;}
.secret-header{display:flex;align-items:center;gap:10px;margin-bottom:18px;border-bottom:1px solid rgba(77,184,255,0.3);padding-bottom:14px;}
.secret-badge{background:var(--blue);color:#000;font-size:0.65rem;font-weight:700;letter-spacing:2px;padding:4px 10px;border-radius:4px;text-transform:uppercase;}
.secret-id{font-size:0.7rem;opacity:0.4;letter-spacing:1px;}
.secret-body{font-size:1rem;line-height:2;color:rgba(255,255,255,0.88);}
.secret-body .line{display:block;opacity:0;transform:translateX(-10px);transition:opacity 0.4s ease,transform 0.4s ease;}
.secret-body .line.visible{opacity:1;transform:translateX(0);}
.secret-footer{margin-top:22px;padding-top:14px;border-top:1px solid rgba(77,184,255,0.2);display:flex;justify-content:space-between;align-items:center;}
.sign{font-style:italic;opacity:0.6;font-size:0.9rem;}
.close-btn{padding:9px 22px;border-radius:20px;border:1px solid var(--blue);background:transparent;color:white;cursor:pointer;font-size:0.9rem;transition:0.3s;}
.close-btn:hover{background:var(--blue);color:#000;}
.gallery{column-count:2;column-gap:12px;margin-top:40px;}
.item{break-inside:avoid;margin-bottom:12px;border-radius:12px;overflow:hidden;}
.item img{width:100%;border-radius:12px;transition:0.4s;display:block;}
.item:hover img{transform:scale(1.03);}
.fade{opacity:0;transform:translateY(20px);transition:0.8s;}
.fade.show{opacity:1;transform:translateY(0);}
</style>
</head>
<body>

<div id="start">
  <button class="start-btn" onclick="start()">🦇 A Surprise from Batman</button>
</div>

<div id="main">
  <div class="hero fade">
    <h1 id="title"></h1>
    <p id="subtitle"></p>
  </div>
  <div class="cake fade">
    <div class="candle"><div class="flame"></div></div>
  </div>
  <h2 class="fade" style="margin-top:10px;">19 🎉</h2>
  <button class="start-btn secret-btn fade" onclick="openSecret()">🦇 Classified: For Your Eyes Only</button>

  <div class="gallery fade">
    <div class="item"><img src="data:image/jpeg;base64," alt="photo"></div>
    <div class="item"><img src="data:image/jpeg;base64," alt="photo"></div>
    <div class="item"><img src="data:image/jpeg;base64," alt="photo"></div>
    <div class="item"><img src="data:image/jpeg;base64," alt="photo"></div>
    <div class="item"><img src="data:image/png;base64," alt="photo"></div>
  </div>
</div>

<div id="popup">
  <div class="popup-box">
    <div class="secret-header">
      <span>🦇</span>
      <span class="secret-badge">Top Secret</span>
      <span class="secret-id">FILE-19 · Eyes Only</span>
    </div>
    <div class="secret-body" id="secretLines">
      <span class="line">Heyyy… it's Batman 🦇</span>
      <span class="line">&nbsp;</span>
      <span class="line">Wishing u the happiest birthday 🎉✨</span>
      <span class="line">&nbsp;</span>
      <span class="line">And as I told u before… next birthday will be special</span>
      <span class="line">after I got u 😁😉</span>
      <span class="line">&nbsp;</span>
      <span class="line">I want to say some gooddddddd things…</span>
      <span class="line">but u are not ready for it now 🥲 so later…..</span>
      <span class="line">&nbsp;</span>
      <span class="line">But I just wish u enjoy ur birthday,</span>
      <span class="line">ur all wishes come true, stay safe,</span>
      <span class="line">don't stress much &amp; stop overthinking 😒😂</span>
      <span class="line">&nbsp;</span>
      <span class="line">I just want to tell u — why can't things be like before?</span>
      <span class="line">Just think about it… we are not like others.</span>
      <span class="line">We understand each other very well.</span>
      <span class="line">We should care about each other.</span>
      <span class="line">Just no more shitty fights 🙄</span>
      <span class="line">We will look out for each other.</span>
      <span class="line">&nbsp;</span>
      <span class="line">We got only one life…</span>
      <span class="line">so let's enjoy it together okay? 🥂</span>
      <span class="line">&nbsp;</span>
      <span class="line">Happy Birthday ✨🎀</span>
    </div>
    <div class="secret-footer">
      <span class="sign">— Batman 🦇</span>
      <button class="close-btn" onclick="closeSecret()">Close ✕</button>
    </div>
  </div>
</div>

<script>
function start(){
  document.getElementById("start").style.display="none";
  document.getElementById("main").style.display="block";
  typeText();
  setTimeout(showAll,1500);
}
function typeText(){
  let text="Happy Birthday patli kamar 🎀 🎉";
  let i=0,el=document.getElementById("title");
  function typing(){if(i<text.length){el.innerHTML+=text[i];i++;setTimeout(typing,50);}}
  typing();
}
function showAll(){
  document.querySelectorAll(".fade").forEach(el=>el.classList.add("show"));
  confetti({particleCount:200,spread:80});
}
setInterval(()=>{
  let heart=document.createElement("div");
  heart.className="heart";
  heart.innerHTML=["❤️","🩷","💕","🦇"][Math.floor(Math.random()*4)];
  heart.style.left=Math.random()*100+"vw";
  heart.style.animationDuration=(4+Math.random()*4)+"s";
  document.body.appendChild(heart);
  setTimeout(()=>heart.remove(),8000);
},500);
function openSecret(){
  document.getElementById("popup").style.display="flex";
  const lines=document.querySelectorAll(".secret-body .line");
  lines.forEach((l,i)=>setTimeout(()=>l.classList.add("visible"),i*80));
}
function closeSecret(){
  document.getElementById("popup").style.display="none";
  document.querySelectorAll(".secret-body .line").forEach(l=>l.classList.remove("visible"));
}
</script>
</body>
</html>
